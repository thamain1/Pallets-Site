---
import { NAV_LINKS, SITE } from "../data/site";

const currentPath = Astro.url.pathname;
const isActive = (href: string) => {
  if (href === "/") return currentPath === "/" || currentPath === "";
  return currentPath.startsWith(href);
};
---

<header class="bg-[#18120b] text-pallet-cream sticky top-0 z-40 shadow-lg shadow-black/20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-3 flex items-center justify-between gap-4">
    <a href="/" class="flex items-center gap-3 group" aria-label="Pallets Pallets Pallets home">
      <span class="inline-flex items-center justify-center w-10 h-10 rounded-md bg-accent text-[#18120b] font-display font-bold text-base shadow-sm group-hover:bg-accent-light transition-colors">
        PPP
      </span>
      <span class="font-display font-semibold text-pallet-cream hidden sm:inline tracking-wider uppercase text-lg">
        {SITE.name}
      </span>
    </a>

    <nav aria-label="Primary">
      <ul class="flex items-center gap-1 sm:gap-1 text-sm font-medium uppercase tracking-wider">
        {NAV_LINKS.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={[
                "px-3 py-2 rounded-md transition-colors",
                isActive(link.href)
                  ? "text-accent font-semibold"
                  : "text-pallet-cream/80 hover:text-accent",
              ]}
              aria-current={isActive(link.href) ? "page" : undefined}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <a
      href={`tel:${SITE.phone}`}
      class="hidden md:inline-flex items-center gap-2 bg-accent hover:bg-accent-light text-[#18120b] px-4 py-2 rounded-md font-bold text-sm transition-colors uppercase tracking-wide"
      aria-label={`Call ${SITE.name} at ${SITE.phoneDisplay}`}
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
      </svg>
      {SITE.phoneDisplay}
    </a>
  </div>
</header>
