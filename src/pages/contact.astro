---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE } from "../data/site";

const title = "Contact Us | Pallets Pallets Pallets — Atlanta";
const description =
  "Call, email, or stop by our Atlanta yard. Quotes and pickups same business day. Hours Mon-Fri 7-5, Sat 8-12.";
---

<BaseLayout title={title} description={description} path="/contact">
  <!-- HERO STRIP -->
  <section class="relative min-h-[44vh] flex items-center text-pallet-cream overflow-hidden">
    <img
      src="/images/cleanpallets.jpg"
      alt=""
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      fetchpriority="high"
      aria-hidden="true"
    />
    <div class="absolute inset-0 hero-overlay"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 py-20 w-full">
      <p class="text-accent font-bold uppercase tracking-widest text-sm mb-3">Contact</p>
      <h1 class="text-5xl sm:text-6xl font-bold leading-[1.05] tracking-tight max-w-3xl">
        Call. Email.<br />
        Stop by the yard.
      </h1>
      <p class="mt-6 text-lg sm:text-xl text-pallet-cream/90 leading-relaxed max-w-2xl">
        Quotes and pickup scheduling same business day. The fastest way to reach us is the phone.
      </p>
    </div>
  </section>

  <!-- CONTACT GRID -->
  <section class="py-20 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 grid gap-6 md:grid-cols-2">
      <a
        href={`tel:${SITE.phone}`}
        class="group bg-pallet-cream border-l-4 border-accent rounded-r-lg p-8 hover:bg-pallet-cream-dark transition-colors"
      >
        <div class="flex items-center gap-3 mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#b45309" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          <h2 class="font-display text-lg font-semibold uppercase tracking-wider text-pallet-wood-dark">Phone</h2>
        </div>
        <p class="font-display text-3xl font-bold text-pallet-wood-dark group-hover:underline">{SITE.phoneDisplay}</p>
        <p class="text-sm text-stone-600 mt-3">Best for quotes, same-day pickups, and standing accounts.</p>
      </a>

      <a
        href={`mailto:${SITE.email}`}
        class="group bg-pallet-cream border-l-4 border-accent rounded-r-lg p-8 hover:bg-pallet-cream-dark transition-colors"
      >
        <div class="flex items-center gap-3 mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#b45309" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
          <h2 class="font-display text-lg font-semibold uppercase tracking-wider text-pallet-wood-dark">Email</h2>
        </div>
        <p class="text-lg font-bold text-pallet-wood-dark group-hover:underline break-words">{SITE.email}</p>
        <p class="text-sm text-stone-600 mt-3">Best for sending photos, attached documents, or specs.</p>
      </a>

      <div class="md:col-span-2 bg-[#18120b] text-pallet-cream rounded-lg p-8">
        <div class="grid gap-8 sm:grid-cols-2">
          <div>
            <div class="flex items-center gap-3 mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M12 21.7C17.3 17 20 13 20 10a8 8 0 1 0-16 0c0 3 2.7 7 8 11.7z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
              <h2 class="font-display text-lg font-semibold uppercase tracking-wider">Yard &amp; office</h2>
            </div>
            <address class="not-italic text-pallet-cream/90 leading-relaxed">
              <strong class="text-pallet-cream">{SITE.legalName}</strong><br />
              {SITE.address.street}<br />
              {SITE.address.locality}, {SITE.address.region} {SITE.address.postalCode}
            </address>
          </div>
          <div>
            <div class="flex items-center gap-3 mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
              <h2 class="font-display text-lg font-semibold uppercase tracking-wider">Hours</h2>
            </div>
            <p class="text-pallet-cream/90">{SITE.hours.weekdays}</p>
            <p class="text-pallet-cream/90">{SITE.hours.weekend}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- INQUIRY FORM -->
  <section class="bg-pallet-cream py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-10">
        <p class="text-accent-dark font-bold uppercase tracking-widest text-sm mb-3">Inquiry form</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-pallet-wood-dark leading-tight">Tell us what you need.</h2>
        <p class="mt-3 text-stone-600 max-w-xl mx-auto">We'll get back to you the same business day. Required fields marked with *.</p>
      </div>

      <div
        id="contact-error"
        class="hidden bg-red-50 border-l-4 border-red-600 text-red-900 px-4 py-3 rounded-r-md mb-6"
        role="alert"
      ></div>

      <form
        action="/api/contact"
        method="POST"
        class="bg-white border border-pallet-cream-dark rounded-lg p-6 sm:p-8 space-y-6 shadow-lg shadow-pallet-wood-dark/5"
        novalidate
      >
        <!-- Honeypot: bots fill this; humans never see it. -->
        <div class="absolute -left-[9999px]" aria-hidden="true">
          <label for="website">Website (leave blank)</label>
          <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
        </div>

        <div class="grid gap-6 sm:grid-cols-2">
          <div>
            <label for="name" class="block text-sm font-bold uppercase tracking-wider text-pallet-wood-dark mb-2">
              Name <span class="text-accent-dark">*</span>
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              autocomplete="name"
              class="w-full px-4 py-3 border border-pallet-cream-dark rounded-md focus:outline-none focus:border-accent focus:ring-2 focus:ring-accent/30 transition-colors"
            />
          </div>

          <div>
            <label for="company" class="block text-sm font-bold uppercase tracking-wider text-pallet-wood-dark mb-2">
              Company
            </label>
            <input
              type="text"
              id="company"
              name="company"
              autocomplete="organization"
              class="w-full px-4 py-3 border border-pallet-cream-dark rounded-md focus:outline-none focus:border-accent focus:ring-2 focus:ring-accent/30 transition-colors"
            />
          </div>

          <div>
            <label for="email" class="block text-sm font-bold uppercase tracking-wider text-pallet-wood-dark mb-2">
              Email <span class="text-accent-dark">*</span>
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              autocomplete="email"
              class="w-full px-4 py-3 border border-pallet-cream-dark rounded-md focus:outline-none focus:border-accent focus:ring-2 focus:ring-accent/30 transition-colors"
            />
          </div>

          <div>
            <label for="phone" class="block text-sm font-bold uppercase tracking-wider text-pallet-wood-dark mb-2">
              Phone
            </label>
            <input
              type="tel"
              id="phone"
              name="phone"
              autocomplete="tel"
              class="w-full px-4 py-3 border border-pallet-cream-dark rounded-md focus:outline-none focus:border-accent focus:ring-2 focus:ring-accent/30 transition-colors"
            />
          </div>
        </div>

        <div>
          <label for="need" class="block text-sm font-bold uppercase tracking-wider text-pallet-wood-dark mb-2">
            What do you need? <span class="text-accent-dark">*</span>
          </label>
          <select
            id="need"
            name="need"
            required
            class="w-full px-4 py-3 border border-pallet-cream-dark rounded-md bg-white focus:outline-none focus:border-accent focus:ring-2 focus:ring-accent/30 transition-colors"
          >
            <option value="">— Select one —</option>
            <option value="pickup">Pickup (broken or surplus pallets)</option>
            <option value="supply">Supply (need pallets delivered)</option>
            <option value="both">Both (pickup + supply)</option>
            <option value="custom">Custom-size pallets</option>
            <option value="other">Something else</option>
          </select>
        </div>

        <div class="grid gap-6 sm:grid-cols-2">
          <div>
            <label for="quantity" class="block text-sm font-bold uppercase tracking-wider text-pallet-wood-dark mb-2">
              Rough quantity
            </label>
            <input
              type="text"
              id="quantity"
              name="quantity"
              placeholder="e.g. ~50 pallets, 1 trailer, a few"
              class="w-full px-4 py-3 border border-pallet-cream-dark rounded-md focus:outline-none focus:border-accent focus:ring-2 focus:ring-accent/30 transition-colors"
            />
          </div>

          <div>
            <label for="when" class="block text-sm font-bold uppercase tracking-wider text-pallet-wood-dark mb-2">
              When?
            </label>
            <input
              type="text"
              id="when"
              name="when"
              placeholder="e.g. ASAP, this week, recurring"
              class="w-full px-4 py-3 border border-pallet-cream-dark rounded-md focus:outline-none focus:border-accent focus:ring-2 focus:ring-accent/30 transition-colors"
            />
          </div>
        </div>

        <div>
          <label for="message" class="block text-sm font-bold uppercase tracking-wider text-pallet-wood-dark mb-2">
            Details <span class="text-accent-dark">*</span>
          </label>
          <textarea
            id="message"
            name="message"
            required
            rows="5"
            placeholder="Address, dock access notes, anything else we should know."
            class="w-full px-4 py-3 border border-pallet-cream-dark rounded-md focus:outline-none focus:border-accent focus:ring-2 focus:ring-accent/30 transition-colors resize-y"
          ></textarea>
        </div>

        <div class="flex flex-wrap items-center justify-between gap-4 pt-2">
          <p class="text-xs text-stone-500">
            Prefer the phone? Call <a href="tel:+14045550000" class="font-bold text-pallet-wood-dark hover:text-accent-dark">{SITE.phoneDisplay}</a>.
          </p>
          <button
            type="submit"
            class="inline-flex items-center gap-2 bg-accent hover:bg-accent-light text-[#18120b] px-7 py-3 rounded-md font-bold text-base uppercase tracking-wide transition-colors"
          >
            Send inquiry →
          </button>
        </div>
      </form>
    </div>

    <script is:inline>
      (function () {
        var params = new URLSearchParams(window.location.search);
        var code = params.get("error");
        if (!code) return;
        var messages = {
          "missing-required": "Please fill in name, email, what-you-need, and details.",
          "bad-email": "That email address doesn't look right — please check it.",
          "invalid-payload": "Something went wrong submitting the form. Please try again.",
          "too-long": "One of the fields is too long. Please shorten it and resubmit.",
          "delivery-failed": "We couldn't deliver your inquiry. Please call us instead.",
        };
        var el = document.getElementById("contact-error");
        if (!el) return;
        el.textContent = messages[code] || "Something went wrong. Please try again or call us.";
        el.classList.remove("hidden");
        el.scrollIntoView({ behavior: "smooth", block: "center" });
      })();
    </script>
  </section>

  <!-- WHAT TO TELL US -->
  <section class="bg-white py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <h2 class="text-2xl sm:text-3xl font-bold text-pallet-wood-dark mb-8 leading-tight text-center">When you call or email, tell us:</h2>

      <ul class="space-y-4">
        {[
          "Your address (or a rough idea of where you are)",
          "What you have (pickup) or what you need (supply) — rough count is fine",
          "When you need it — today, this week, recurring",
          "Dock access notes (lift gate? back-in only? gated yard?)",
        ].map((item) => (
          <li class="flex gap-4 bg-pallet-cream border border-pallet-cream-dark rounded-lg p-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#b45309" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0 mt-0.5" aria-hidden="true">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            <span class="text-stone-700">{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>
