---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE, TRUST_BADGES, STATS } from "../data/site";

const title = "Pallet Supplier & Recycling | Pallets Pallets Pallets";
const description =
  "Atlanta-area pallet supplier and recycler. New, recycled, and custom wooden pallets — Grade A and Grade B. Pickup and reclamation across the metro region.";

const services = [
  {
    title: "Pallet Supply",
    blurb: "Standard and custom wooden pallets, ready to ship.",
    image: "/images/cleanpallets.jpg",
    alt: "Stacks of newly assembled wooden pallets in a warehouse",
  },
  {
    title: "Pickup & Recycling",
    blurb: "We haul away broken, surplus, or wrong-size pallets.",
    image: "/images/pallets.jpg",
    alt: "Tall stack of mixed used wooden pallets ready for pickup at a loading dock",
  },
  {
    title: "Custom Sizes",
    blurb: "Built-to-spec for awkward loads. Short-run friendly.",
    image: "/images/typesofpallets.jpg",
    alt: "Diagram of nine different wooden pallet types and configurations",
  },
  {
    title: "Grade A & B",
    blurb: "Export-friendly and general-warehouse stock in inventory.",
    image: "/images/stackspallets.jpg",
    alt: "Large outdoor stacks of recycled wooden pallets at a pallet yard",
  },
];
---

<BaseLayout title={title} description={description} path="/">
  <!-- HERO -->
  <section class="relative min-h-[88vh] flex items-center text-pallet-cream overflow-hidden">
    <img
      src="/images/stackspallets.jpg"
      alt="Tall outdoor stacks of recycled wooden pallets at the Pallets Pallets Pallets Atlanta yard"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 hero-overlay"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 py-20 lg:py-28 w-full">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 bg-accent text-[#18120b] px-3 py-1 rounded-sm font-bold text-xs uppercase tracking-widest mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-[#18120b]"></span>
          Serving Atlanta &amp; the Southeast
        </div>

        <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold leading-[1.05] tracking-tight">
          Pallets in.<br />
          Pallets out.<br />
          <span class="text-accent">Done right.</span>
        </h1>

        <p class="mt-6 text-lg sm:text-xl text-pallet-cream/90 leading-relaxed max-w-xl">
          Atlanta's source for new, recycled, and custom wooden pallets — and the fast pickup that gets broken or surplus stock off your dock the same week.
        </p>

        <div class="mt-10 flex flex-wrap gap-3">
          <a
            href={`tel:${SITE.phone}`}
            class="inline-flex items-center gap-2 bg-accent hover:bg-accent-light text-[#18120b] px-7 py-4 rounded-md font-bold text-lg uppercase tracking-wide transition-colors shadow-xl shadow-black/30"
          >
            Call {SITE.phoneDisplay}
          </a>
          <a
            href="/contact"
            class="inline-flex items-center gap-2 bg-transparent border-2 border-pallet-cream text-pallet-cream px-7 py-4 rounded-md font-bold text-lg uppercase tracking-wide hover:bg-pallet-cream hover:text-[#18120b] transition-colors"
          >
            Get a quote
          </a>
        </div>
      </div>
    </div>

    <!-- Trust strip on the hero -->
    <div class="absolute bottom-0 left-0 right-0 bg-[#18120b]/85 backdrop-blur-sm border-t border-accent/30">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 py-4 flex flex-wrap justify-center sm:justify-between items-center gap-4 text-sm uppercase tracking-wider font-medium">
        {TRUST_BADGES.map((badge) => (
          <div class="flex items-center gap-2 text-pallet-cream">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            {badge}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STATS BAND -->
  <section class="bg-[#18120b] text-pallet-cream py-12 border-y-4 border-accent">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 grid grid-cols-2 lg:grid-cols-4 gap-8">
      {STATS.map((stat) => (
        <div class="text-center">
          <div class="font-display text-4xl sm:text-5xl font-bold text-accent leading-none">
            {stat.value}<span class="text-2xl sm:text-3xl">{stat.suffix}</span>
          </div>
          <div class="mt-2 text-xs sm:text-sm uppercase tracking-widest text-pallet-cream/70">
            {stat.label}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- WHAT WE DO — photo cards -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="max-w-2xl mb-12">
        <p class="text-accent-dark font-bold uppercase tracking-widest text-sm mb-3">What we do</p>
        <h2 class="text-4xl sm:text-5xl font-bold text-pallet-wood-dark leading-tight">Two sides. One operation.</h2>
        <p class="mt-4 text-stone-600 text-lg">
          Pallets are dirty, heavy, and a real operations headache when they pile up or run short. We handle both ends.
        </p>
      </div>

      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {services.map((service) => (
          <a
            href="/services"
            class="group relative aspect-[3/4] rounded-lg overflow-hidden block focus-visible:outline focus-visible:outline-2 focus-visible:outline-accent"
          >
            <img
              src={service.image}
              alt={service.alt}
              class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
            <div class="absolute inset-0 card-overlay"></div>
            <div class="absolute inset-0 p-6 flex flex-col justify-end text-pallet-cream">
              <h3 class="font-display text-2xl font-bold uppercase tracking-wider leading-tight">
                {service.title}
              </h3>
              <p class="mt-2 text-sm text-pallet-cream/90 leading-relaxed">
                {service.blurb}
              </p>
              <span class="mt-4 text-accent text-sm font-bold uppercase tracking-widest inline-flex items-center gap-1 group-hover:gap-3 transition-all">
                Learn more →
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- RECYCLING PROCESS — featured photo + 3 steps -->
  <section class="bg-pallet-cream py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 grid gap-12 lg:grid-cols-2 items-center">
      <div class="relative aspect-[4/3] rounded-lg overflow-hidden shadow-2xl shadow-pallet-wood-dark/30">
        <img
          src="/images/palletrepair.PNG"
          alt="A worker repairing a damaged wooden pallet on a workbench using a power drill"
          class="absolute inset-0 w-full h-full object-cover"
          loading="lazy"
        />
        <div class="absolute top-4 left-4 bg-accent text-[#18120b] px-3 py-1 rounded-sm font-bold text-xs uppercase tracking-widest">
          Inside our yard
        </div>
      </div>

      <div>
        <p class="text-accent-dark font-bold uppercase tracking-widest text-sm mb-3">Cradle to cradle</p>
        <h2 class="text-4xl sm:text-5xl font-bold text-pallet-wood-dark leading-tight mb-6">
          From your dock back into rotation.
        </h2>
        <p class="text-stone-700 text-lg leading-relaxed mb-8">
          Every pickup comes back to our Atlanta yard, gets inspected, sorted, and either repaired and re-inventoried or ground for biomass. Nothing gets dumped.
        </p>

        <ol class="space-y-5">
          <li class="flex gap-4">
            <span class="flex-shrink-0 w-10 h-10 rounded-full bg-accent text-[#18120b] font-display font-bold flex items-center justify-center text-lg">1</span>
            <div>
              <h3 class="font-display text-lg font-semibold text-pallet-wood-dark uppercase tracking-wide mb-1">Pickup</h3>
              <p class="text-stone-600">Scheduled or on-call. Single pallets to full trailers.</p>
            </div>
          </li>
          <li class="flex gap-4">
            <span class="flex-shrink-0 w-10 h-10 rounded-full bg-accent text-[#18120b] font-display font-bold flex items-center justify-center text-lg">2</span>
            <div>
              <h3 class="font-display text-lg font-semibold text-pallet-wood-dark uppercase tracking-wide mb-1">Sort &amp; repair</h3>
              <p class="text-stone-600">Deck boards, stringers, and lead boards replaced as needed.</p>
            </div>
          </li>
          <li class="flex gap-4">
            <span class="flex-shrink-0 w-10 h-10 rounded-full bg-accent text-[#18120b] font-display font-bold flex items-center justify-center text-lg">3</span>
            <div>
              <h3 class="font-display text-lg font-semibold text-pallet-wood-dark uppercase tracking-wide mb-1">Redistribute</h3>
              <p class="text-stone-600">Back into the supply rotation. Beyond repair → biomass, never landfill.</p>
            </div>
          </li>
        </ol>
      </div>
    </div>
  </section>

  <!-- MADE IN USA -->
  <section class="bg-[#18120b] text-pallet-cream py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 grid gap-12 lg:grid-cols-2 items-center">
      <div class="order-2 lg:order-1">
        <p class="text-accent font-bold uppercase tracking-widest text-sm mb-3">Built local</p>
        <h2 class="text-4xl sm:text-5xl font-bold leading-tight mb-6">
          Made in the USA.<br />
          <span class="text-accent">Rebuilt in Atlanta.</span>
        </h2>
        <p class="text-pallet-cream/80 text-lg leading-relaxed mb-6">
          Every pallet we supply is made or remanufactured in the United States. Our remanufactured stock is repaired right at our South River Industrial yard, by a team that's been doing this work for years.
        </p>
        <p class="text-pallet-cream/80 text-lg leading-relaxed">
          Family-run, owner-on-the-yard, and answering the phone when you call. Not a brokerage. Not a call center.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href="/about"
            class="inline-flex items-center gap-2 bg-accent hover:bg-accent-light text-[#18120b] px-6 py-3 rounded-md font-bold uppercase tracking-wide transition-colors"
          >
            Our story
          </a>
          <a
            href={`tel:${SITE.phone}`}
            class="inline-flex items-center gap-2 border-2 border-pallet-cream/40 text-pallet-cream px-6 py-3 rounded-md font-bold uppercase tracking-wide hover:border-pallet-cream hover:bg-pallet-cream/10 transition-colors"
          >
            {SITE.phoneDisplay}
          </a>
        </div>
      </div>
      <div class="order-1 lg:order-2 relative">
        <div class="aspect-square rounded-lg bg-pallet-cream/5 border border-pallet-cream/10 p-8 flex items-center justify-center">
          <img
            src="/images/madeinusa.jpg"
            alt="A new wooden pallet with a Made in USA badge featuring an American flag"
            class="max-w-full max-h-full object-contain drop-shadow-2xl"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICE AREA TEASER -->
  <section class="relative py-20 overflow-hidden">
    <img
      src="/images/pallets.jpg"
      alt=""
      class="absolute inset-0 w-full h-full object-cover"
      loading="lazy"
      aria-hidden="true"
    />
    <div class="absolute inset-0 bg-pallet-wood-dark/85"></div>

    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 text-center text-pallet-cream">
      <p class="text-accent font-bold uppercase tracking-widest text-sm mb-3">Service area</p>
      <h2 class="text-4xl sm:text-5xl font-bold leading-tight mb-6">
        Atlanta + 3 hours in every direction.
      </h2>
      <p class="text-pallet-cream/90 text-lg leading-relaxed mb-8 max-w-2xl mx-auto">
        From inside the perimeter to Macon, Columbus, Athens, Gainesville, Rome, and up into Chattanooga — if you're within a few hours of Atlanta, we likely already run a route near you.
      </p>
      <a
        href="/service-area"
        class="inline-flex items-center gap-2 bg-accent hover:bg-accent-light text-[#18120b] px-7 py-4 rounded-md font-bold uppercase tracking-wide transition-colors"
      >
        See the full service area
      </a>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="bg-pallet-cream py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <p class="text-accent-dark font-bold uppercase tracking-widest text-sm mb-3">Ready when you are</p>
      <h2 class="text-4xl sm:text-5xl font-bold text-pallet-wood-dark leading-tight mb-6">
        Need a quote or a pickup?
      </h2>
      <p class="text-stone-700 text-lg mb-10 max-w-2xl mx-auto">
        Tell us what you have on the dock, what you need delivered, or both. We get back to you the same business day.
      </p>
      <div class="flex flex-wrap gap-3 justify-center">
        <a
          href={`tel:${SITE.phone}`}
          class="inline-flex items-center gap-2 bg-accent hover:bg-accent-light text-[#18120b] px-7 py-4 rounded-md font-bold text-lg uppercase tracking-wide transition-colors"
        >
          Call {SITE.phoneDisplay}
        </a>
        <a
          href={`mailto:${SITE.email}`}
          class="inline-flex items-center gap-2 border-2 border-pallet-wood-dark text-pallet-wood-dark px-7 py-4 rounded-md font-bold text-lg uppercase tracking-wide hover:bg-pallet-wood-dark hover:text-pallet-cream transition-colors"
        >
          Email us
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
